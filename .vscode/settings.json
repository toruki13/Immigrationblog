{
    "editor.quickSuggestions": {
        "strings": true
    },
    "eslint.workingDirectories": [
        {
            "pattern": "./apps/*/"
        },
        {
            "pattern": "./ghost/*/"
        }
    ],
    "search.exclude": {
        "**/.git": true,
        "**/build/*": true,
        "**/coverage/**": true,
        "**/dist/**": true,
        "**/ghost.map": true,
        "**/node_modules": true,
        "ghost/core/core/built/**": true,
        "**/config.*.json": false,
        "**/config.*.jsonc": false
    },
    "tailwindCSS.experimental.classRegex": [
        ["clsx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
    ],
    "git.detectSubmodules": false,
    "[typescript]": {
        "editor.defaultFormatter": "dbaeumer.vscode-eslint"
    },
    "workbench.colorCustomizations": {
        "activityBar.background": "#464F0E",
        "titleBar.activeBackground": "#626F13",
        "titleBar.activeForeground": "#F9FBEA",
        "titleBar.inactiveBackground": "#464F0E",
        "titleBar.inactiveForeground": "#F9FBEA",
        "statusBar.background": "#464F0E",
        "statusBar.foreground": "#F9FBEA",
        "statusBar.debuggingBackground": "#464F0E",
        "statusBar.debuggingForeground": "#F9FBEA",
        "statusBar.noFolderBackground": "#464F0E",
        "statusBar.noFolderForeground": "#F9FBEA"
    }
}
